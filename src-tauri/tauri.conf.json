{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "lil-pdf",
  "version": "1.0.1",
  "identifier": "com.user.lil-pdf",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "LIL-PDF",
        "width": 1100,
        "height": 700,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/lugomartin/lil-pdf/releases/latest/download/update.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDc3OUQyODMwMjY1MzUzMDgKUldRSVUxTW1NQ2lkZHoybFpKeDRMSnpicXNFS0RXUHpGVTRUYk1LQllqTy9TWXZhRU5kOS9WeWgK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}